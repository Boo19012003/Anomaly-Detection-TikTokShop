# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Python files
*.py text eol=lf

# Config / text files
*.txt text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
.gitignore text eol=lf

# Binary files — no conversion
*.pt binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pkl binary
*.zip binary
*.onnx binary
